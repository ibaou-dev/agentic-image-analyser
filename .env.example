# =============================================================================
# agentic-vision — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
# =============================================================================

# ─── Google / Gemini ──────────────────────────────────────────────────────────

# Google Cloud Project ID (for Code Assist / Antigravity endpoint).
# If you use the Gemini CLI, this is typically already set in your shell.
# GOOGLE_CLOUD_PROJECT=my-gcp-project-id

# Path to Gemini CLI OAuth credentials (auto-detected from default location).
# Override only if your Gemini CLI stores credentials elsewhere.
# GEMINI_OAUTH_CREDS_PATH=~/.gemini/oauth_creds.json

# Gemini API key (alternative to OAuth; obtain from https://aistudio.google.com/apikey)
# GEMINI_API_KEY=AIza...

# ─── OpenAI-compatible ────────────────────────────────────────────────────────

# Standard OpenAI API key
# OPENAI_API_KEY=sk-...

# Override base URL for OpenAI-compatible endpoints (local LLMs, proxies, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Anthropic / Claude ───────────────────────────────────────────────────────

# ANTHROPIC_API_KEY=sk-ant-...

# ─── Gemini CLI OAuth client credentials ──────────────────────────────────────
# Only needed if token refresh fails and auto-extraction from Gemini CLI breaks.
# These are extracted automatically from the installed Gemini CLI package.
# GEMINI_CLI_OAUTH_CLIENT_ID=...
# GEMINI_CLI_OAUTH_CLIENT_SECRET=...

# ─── Development / Testing ────────────────────────────────────────────────────

# Set to 1 to run integration tests (requires real credentials and network access)
# AGENTIC_VISION_INTEGRATION_TEST=1

# Set to 1 for verbose HTTP logging during debugging
# AGENTIC_VISION_DEBUG=0
